#!/bin/sh
# skills/prompt-history/ is the canonical source of truth.
# Mirror SKILL.md and references/ to .claude/skills/prompt-history/ before every commit.

CANONICAL_DIR="skills/prompt-history"
MIRROR_DIR=".claude/skills/prompt-history"

if [ -d "$CANONICAL_DIR" ]; then
    cp "$CANONICAL_DIR/SKILL.md" "$MIRROR_DIR/SKILL.md"
    cp -r "$CANONICAL_DIR/references/" "$MIRROR_DIR/references/"
    git add "$MIRROR_DIR/SKILL.md" "$MIRROR_DIR/references/"
fi
